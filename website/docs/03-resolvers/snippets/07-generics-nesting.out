import { GraphQLSchema, GraphQLObjectType, GraphQLBoolean } from "graphql";
export function getSchema(): GraphQLSchema {
    const PageInfoType: GraphQLObjectType = new GraphQLObjectType({
        name: "PageInfo",
        fields() {
            return {
                hasNextPage: {
                    name: "hasNextPage",
                    type: GraphQLBoolean
                }
            };
        }
    });
    return new GraphQLSchema({
        types: [PageInfoType]
    });
}
