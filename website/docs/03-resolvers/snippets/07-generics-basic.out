import { GraphQLSchema, GraphQLObjectType, GraphQLString } from "graphql";
export function getSchema(): GraphQLSchema {
    const GqlErrorType: GraphQLObjectType = new GraphQLObjectType({
        name: "GqlError",
        fields() {
            return {
                message: {
                    name: "message",
                    type: GraphQLString
                }
            };
        }
    });
    return new GraphQLSchema({
        types: [GqlErrorType]
    });
}
