import { GraphQLSchema, GraphQLObjectType, GraphQLString } from "graphql";
export function getSchema(): GraphQLSchema {
    const MyClassType: GraphQLObjectType = new GraphQLObjectType({
        name: "MyClass",
        fields() {
            return {
                myField: {
                    name: "myField",
                    type: GraphQLString,
                    args: {
                        greeting: {
                            deprecationReason: "Unused!",
                            type: GraphQLString
                        }
                    },
                    resolve(source, args) {
                        return source.myField(args.greeting);
                    }
                }
            };
        }
    });
    return new GraphQLSchema({
        types: [MyClassType]
    });
}
