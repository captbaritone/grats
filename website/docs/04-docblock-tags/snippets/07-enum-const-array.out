import { GraphQLSchema, GraphQLEnumType } from "graphql";
export function getSchema(): GraphQLSchema {
    const StatusType: GraphQLEnumType = new GraphQLEnumType({
        name: "Status",
        values: {
            ARCHIVED: {
                value: "ARCHIVED"
            },
            DRAFT: {
                value: "DRAFT"
            },
            PUBLISHED: {
                value: "PUBLISHED"
            }
        }
    });
    return new GraphQLSchema({
        types: [StatusType]
    });
}
