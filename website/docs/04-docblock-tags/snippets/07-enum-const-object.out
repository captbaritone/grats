import { GraphQLSchema, GraphQLEnumType } from "graphql";
export function getSchema(): GraphQLSchema {
    const StatusType: GraphQLEnumType = new GraphQLEnumType({
        name: "Status",
        values: {
            DRAFT: {
                description: "Currently being edited",
                value: "DRAFT"
            },
            HIDDEN: {
                deprecationReason: "Use DRAFT instead",
                value: "HIDDEN"
            },
            PUBLISHED: {
                description: "Available to readers",
                value: "PUBLISHED"
            }
        }
    });
    return new GraphQLSchema({
        types: [StatusType]
