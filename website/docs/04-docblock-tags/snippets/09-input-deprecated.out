import { GraphQLSchema, GraphQLInputObjectType, GraphQLInt, GraphQLNonNull, GraphQLString } from "graphql";
export function getSchema(): GraphQLSchema {
    const MyInputType: GraphQLInputObjectType = new GraphQLInputObjectType({
        name: "MyInput",
        fields() {
            return {
                age: {
                    deprecationReason: "Don't ask for age any more",
                    name: "age",
                    type: GraphQLInt
                },
                name: {
                    name: "name",
                    type: new GraphQLNonNull(GraphQLString)
                }
            };
        }
    });
    return new GraphQLSchema({
        types: [MyInputType]
    });
}
