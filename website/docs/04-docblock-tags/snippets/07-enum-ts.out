import { GraphQLSchema, GraphQLEnumType } from "graphql";
export function getSchema(): GraphQLSchema {
    const MyEnumType: GraphQLEnumType = new GraphQLEnumType({
        description: "A description of my enum.",
        name: "MyEnum",
        values: {
            ERROR: {
                description: "A description of my other variant",
                value: "ERROR"
            },
            OK: {
                description: "A description of my variant",
                value: "OK"
            }
        }
    });
    return new GraphQLSchema({
        types: [MyEnumType]
    });
}
