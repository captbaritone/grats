import { GraphQLSchema, GraphQLEnumType } from "graphql";
export function getSchema(): GraphQLSchema {
    const MyEnumType: GraphQLEnumType = new GraphQLEnumType({
        name: "MyEnum",
        values: {
            ERROR: {
                value: "ERROR"
            },
            OK: {
                value: "OK"
            },
            OKAY: {
                deprecationReason: "Please use OK instead.",
                value: "OKAY"
            }
        }
    });
    return new GraphQLSchema({
        types: [MyEnumType]
    });
}
