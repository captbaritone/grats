=== SNIP ===
import { GraphQLSchema, GraphQLUnionType, GraphQLObjectType, GraphQLString } from "graphql";
export function getSchema(): GraphQLSchema {
    const UserType: GraphQLObjectType = new GraphQLObjectType({
        name: "User",
        fields() {
            return {
                name: {
                    name: "name",
                    type: GraphQLString
                }
            };
        }
    });
    const PostType: GraphQLObjectType = new GraphQLObjectType({
        name: "Post",
        fields() {
            return {
                author: {
                    name: "author",
                    type: UserType
                },
                content: {
                    name: "content",
                    type: GraphQLString
                }
            };
        }
    });
    const MyUnionType: GraphQLUnionType = new GraphQLUnionType({
        name: "MyUnion",
        description: "A description of my union.",
        types() {
            return [PostType, UserType];
        }
    });
    return new GraphQLSchema({
        types: [MyUnionType, PostType, UserType]
    });
}
