import { GraphQLSchema, GraphQLObjectType, GraphQLString } from "graphql";
import { someField as querySomeFieldResolver, adminCheck } from "./09-permissions-assert-token-usage.grats";
export function getSchema(): GraphQLSchema {
    const QueryType: GraphQLObjectType = new GraphQLObjectType({
        name: "Query",
        fields() {
            return {
                someField: {
                    description: "This field will throw for any user that is not an admin. This is enabled\nsimply by adding an argument typed as `AssertAdminToken`, even if it's\nunused.",
                    name: "someField",
                    type: GraphQLString,
                    resolve(_source, _args, context) {
                        return querySomeFieldResolver(adminCheck(context));
                    }
                }
            };
        }
    });
    return new GraphQLSchema({
        query: QueryType,
        types: [QueryType]
    });
}
