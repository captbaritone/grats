{
  "grats": {
    "nullableByDefault": true,
    "strictSemanticNullability": true,
    "importModuleSpecifierEnding": ".js"
  },
  "compilerOptions": {
    "outDir": "dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "esnext",
    "lib": ["esnext"],
    "strict": true,
    "skipLibCheck": true
  }
}
